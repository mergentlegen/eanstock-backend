# Runtime
ENVIRONMENT=development
NODE_ENV=development
BACKEND_PORT=3000
FRONTEND_PORT=5173
PORT=3000
APP_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Data stores: use compose service names, not localhost, inside Docker.
DATABASE_URL=postgresql://leanstock:leanstock@postgres:5432/leanstock?schema=public
REDIS_URL=redis://redis:6379/0

# JWT: generate long random values before production deployment.
JWT_SECRET_KEY=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET_KEY=replace-with-at-least-32-random-characters
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=14

# Security and inventory behavior
AUTH_RATE_LIMIT_POINTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
TRANSFER_LOCK_TTL_MS=8000
RESERVATION_TTL_SECONDS=900
LOW_STOCK_THRESHOLD_DAYS=5

# Background workers
RUN_WORKERS_IN_API=false
ENABLE_DEAD_STOCK_WORKER=true
DEAD_STOCK_DECAY_CRON=0 * * * *

# Email. For production, set EMAIL_DRIVER=smtp and put your provider API key
# or SMTP app password in EMAIL_API_KEY/SMTP_PASS through the cloud dashboard.
EMAIL_DRIVER=log
EMAIL_API_KEY=replace-with-sendgrid-mailgun-ses-or-smtp-api-key
EMAIL_FROM_ADDRESS=LeanStock <verified-sender@example.com>
EMAIL_FROM=LeanStock <verified-sender@example.com>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey-or-smtp-username
SMTP_PASS=replace-with-provider-api-key
EMAIL_VERIFICATION_TTL_MINUTES=60
PASSWORD_RESET_TTL_MINUTES=30
