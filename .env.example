NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://leanstock:leanstock@postgres:5432/leanstock?schema=public
REDIS_URL=redis://redis:6379
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=14
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
AUTH_RATE_LIMIT_POINTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
TRANSFER_LOCK_TTL_MS=8000
