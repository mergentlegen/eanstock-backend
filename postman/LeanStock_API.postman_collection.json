              "pm.collectionVariables.set('username', `owner_${stamp}`);",
              "pm.collectionVariables.set('codeA', `SHOP_A_${stamp}`);",
              "pm.collectionVariables.set('codeB', `SHOP_B_${stamp}`);",
              "pm.collectionVariables.set('sku', `MILK_${stamp}`);",
              "pm.collectionVariables.unset('accessToken');",
              "pm.collectionVariables.unset('refreshToken');",
              "pm.collectionVariables.unset('locationAId');",
              "pm.collectionVariables.unset('locationBId');",
              "pm.collectionVariables.unset('productId');"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('register created user', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('accessToken', json.accessToken);",
              "pm.collectionVariables.set('refreshToken', json.refreshToken);",
              "pm.test('tokens exist', () => {",
              "  pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
              "  pm.expect(json.refreshToken).to.be.a('string').and.not.empty;",
